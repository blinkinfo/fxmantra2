# Privy - Get from https://console.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id
PRIVY_APP_SECRET=your_privy_app_secret

# Database - Get from https://neon.tech
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Platform custodial wallet address (your wallet that receives deposits)
NEXT_PUBLIC_PLATFORM_WALLET_ADDRESS=0xYourPlatformWalletAddress

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:5000
